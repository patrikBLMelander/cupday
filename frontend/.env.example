# Optional. When set, the dev frontend talks to a real backend at this URL
# and the MSW worker is skipped entirely.
#
# To run the local end-to-end stack:
#   1. Copy this file to .env.development.local (Vite picks it up; gitignored).
#   2. Boot the backend stack:        docker compose up --build
#   3. Boot the frontend dev server:  cd frontend && npm run dev
#   4. Open http://localhost:5173
#
# Without VITE_API_BASE_URL set, the frontend uses MSW handlers in the
# browser and never hits the backend (the existing pure-frontend dev mode).
VITE_API_BASE_URL=http://localhost:8080/api
